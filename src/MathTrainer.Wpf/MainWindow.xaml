<Window x:Class="MathTrainer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тренажёр устного счёта" Height="560" Width="720"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <!-- Корневая сетка. Цвета задаются в code-behind при смене темы. -->
    <Grid x:Name="RootGrid" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель настроек -->
        <Border Grid.Row="0" x:Name="SettingsPanel" CornerRadius="8" Padding="12" BorderThickness="1"
                Background="White" BorderBrush="#D0D0D0">
            <WrapPanel>
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="Тип заданий" FontSize="11"/>
                    <ComboBox x:Name="TypeBox" Width="180"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="Сложность" FontSize="11"/>
                    <ComboBox x:Name="DifficultyBox" Width="120"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="Режим" FontSize="11"/>
                    <ComboBox x:Name="ModeBox" Width="120"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="Заданий" FontSize="11"/>
                    <TextBox x:Name="CountBox" Width="60"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="Лимит, c" FontSize="11"/>
                    <TextBox x:Name="TimeBox" Width="60"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="StartButton" Content="▶ Старт (Enter)" Width="160" Height="34" Click="Start_Click"/>
            <Button x:Name="StopButton" Content="■ Стоп (Esc)" Width="100" Height="34" Margin="8,0,0,0" Click="Stop_Click" IsEnabled="False"/>
            <Button x:Name="HelpButton" Content="Справка (F1)" Width="140" Height="34" Margin="8,0,0,0" Click="Help_Click"/>
        </StackPanel>

        <!-- Область задания -->
        <Border Grid.Row="2" x:Name="QuestionPanel" CornerRadius="8" Margin="0,12,0,0" Padding="20" BorderThickness="1"
                Background="White" BorderBrush="#D0D0D0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="QuestionText" Text="Нажмите «Старт», чтобы начать"
                           FontSize="40" TextAlignment="Center" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <TextBox x:Name="AnswerBox" Width="200" FontSize="24" IsEnabled="False"
                             VerticalContentAlignment="Center"/>
                    <Button x:Name="SubmitButton" Content="Ответить" Width="120" Height="40"
                            Margin="12,0,0,0" FontSize="16" IsEnabled="False" Click="Submit_Click"/>
                </StackPanel>
                <TextBlock x:Name="FeedbackText" Text="" FontSize="18" TextAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <!-- Нижняя строка состояния -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="Progress" Height="20" Minimum="0" Maximum="100" Value="0"/>
            <TextBlock x:Name="StatusText" Grid.Column="1" Margin="12,0,0,0"
                       VerticalAlignment="Center" Text="Готов к работе"/>
        </Grid>
    </Grid>
</Window>
